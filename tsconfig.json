{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "noImplicitAny": true
  },

  "include": [
    "src"
  ]
}